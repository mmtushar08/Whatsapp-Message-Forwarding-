# ============================================================
# WhatsApp Message Forwarding App - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit your actual .env file to Git!
# ============================================================

# ----------------------------
# WhatsApp Cloud API Credentials
# (Get these from Meta Developer Dashboard)
# ----------------------------
WHATSAPP_ACCESS_TOKEN=your_access_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here

# ----------------------------
# Forwarding Configuration
# The phone number to forward messages TO
# Include country code, NO + sign (e.g., 12345678900 for +1 234 567 8900)
# ----------------------------
FORWARD_TO_NUMBER=12345678900

# ----------------------------
# Multi-number forwarding (comma-separated, overrides FORWARD_TO_NUMBER if set)
# Example: FORWARD_TO_NUMBERS=12345678900,19876543210
# ----------------------------
FORWARD_TO_NUMBERS=

# ----------------------------
# Webhook Verification Token
# Choose any secret string — must match what you set in Meta dashboard
# ----------------------------
WEBHOOK_VERIFY_TOKEN=my_super_secret_verify_token

# ----------------------------
# Server Configuration
# ----------------------------
PORT=3000

# ----------------------------
# Optional: Keyword Filters
# Comma-separated list of keywords. Leave empty to forward ALL messages.
# Example: KEYWORD_FILTERS=urgent,important,order
# ----------------------------
KEYWORD_FILTERS=

# ----------------------------
# Logging
# Levels: error, warn, info, debug
# ----------------------------
LOG_LEVEL=info

# ----------------------------
# Admin token to protect the phone number update API
# ----------------------------
ADMIN_TOKEN=choose_a_strong_secret_here

# ----------------------------
# Optional: WhatsApp App Secret
# Get this from your Meta App Dashboard (Settings > Basic > App Secret)
# Used to verify X-Hub-Signature-256 on incoming webhooks (recommended for production)
# ----------------------------
WHATSAPP_APP_SECRET=   # Optional but recommended: your Meta App Secret for webhook signature verification

# ----------------------------
# Retry configuration
# ----------------------------
MAX_RETRY_ATTEMPTS=3
RETRY_BASE_DELAY_MS=1000

# ----------------------------
# Optional: Database path
# Default: data/forwarder.db (relative to working directory)
# ----------------------------
DB_PATH=data/forwarder.db

# ----------------------------
# CORS origin for the dashboard frontend
# Set to your Vercel dashboard URL in production, e.g. https://your-app.vercel.app
# Defaults to * (all origins) if not set — REQUIRED in production
# ----------------------------
CORS_ORIGIN=

# ----------------------------
# Encryption key for secrets stored in the database (access tokens, app secrets)
# REQUIRED. Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Keep this secret and never rotate it — rotating will corrupt all stored workspace credentials
# ----------------------------
APP_ENCRYPTION_KEY=

# ----------------------------
# Public-facing URL of this server
# Used to generate the webhook URL shown to users during onboarding
# Example: https://api.yourdomain.com
# Falls back to the incoming request host if not set
# ----------------------------
PUBLIC_APP_URL=

# ----------------------------
# Session TTL in hours (default: 24)
# ----------------------------
SESSION_TTL_HOURS=24

# ----------------------------
# WhatsApp Graph API call timeout in milliseconds (default: 10000)
# ----------------------------
WHATSAPP_TIMEOUT_MS=10000

# ----------------------------
# SMTP configuration for email forwarding (optional)
# If SMTP_HOST is blank, email forwarding is disabled (users can still configure
# a destination email, but no mail will be sent until SMTP is configured)
# Examples:
#   SendGrid: SMTP_HOST=smtp.sendgrid.net  SMTP_PORT=587  SMTP_USER=apikey
#   AWS SES:  SMTP_HOST=email-smtp.us-east-1.amazonaws.com  SMTP_PORT=587
#   Gmail:    SMTP_HOST=smtp.gmail.com  SMTP_PORT=465  SMTP_SECURE=true
# ----------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ----------------------------
# Razorpay subscription billing (optional — leave blank to disable paid plans)
# Get these from Razorpay Dashboard → Settings → API Keys
# Plan IDs: Create subscription plans in Razorpay Dashboard → Subscriptions → Plans
# Webhook secret: Razorpay Dashboard → Settings → Webhooks
# ----------------------------
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_PLAN_STARTER=
RAZORPAY_PLAN_PRO=
RAZORPAY_PLAN_BUSINESS=

# ---- AI Auto-Responder (optional) ------------------------------------
# Get your API key from https://console.anthropic.com
# If blank, the AI auto-reply feature is disabled globally.
ANTHROPIC_API_KEY=
