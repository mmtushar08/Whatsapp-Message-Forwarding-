# WhatsApp Cloud API Credentials
WHATSAPP_ACCESS_TOKEN=your_access_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here

# The number to forward messages TO (with country code, no + sign)
FORWARD_TO_NUMBER=1234567890

# Webhook verification token (you choose this, must match Meta dashboard)
WEBHOOK_VERIFY_TOKEN=your_webhook_verify_token_here

# Server port
PORT=3000

# Optional: Keyword filter (comma-separated). Leave empty to forward ALL messages.
# Example: KEYWORD_FILTERS=urgent,important,order
KEYWORD_FILTERS=

# Log level
LOG_LEVEL=info
