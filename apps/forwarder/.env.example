# ============================================================
# WhatsApp Message Forwarding App - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit your actual .env file to Git!
# ============================================================

# ----------------------------
# WhatsApp Cloud API Credentials
# (Get these from Meta Developer Dashboard)
# ----------------------------
WHATSAPP_ACCESS_TOKEN=your_access_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here

# ----------------------------
# Forwarding Configuration
# The phone number to forward messages TO
# Include country code, NO + sign (e.g., 12345678900 for +1 234 567 8900)
# ----------------------------
FORWARD_TO_NUMBER=12345678900

# ----------------------------
# Webhook Verification Token
# Choose any secret string — must match what you set in Meta dashboard
# ----------------------------
WEBHOOK_VERIFY_TOKEN=my_super_secret_verify_token

# ----------------------------
# Server Configuration
# ----------------------------
PORT=3000

# ----------------------------
# Optional: Keyword Filters
# Comma-separated list of keywords. Leave empty to forward ALL messages.
# Example: KEYWORD_FILTERS=urgent,important,order
# ----------------------------
KEYWORD_FILTERS=

# ----------------------------
# Logging
# Levels: error, warn, info, debug
# ----------------------------
LOG_LEVEL=info

# ----------------------------
# Admin token to protect the phone number update API
# ----------------------------
ADMIN_TOKEN=choose_a_strong_secret_here
